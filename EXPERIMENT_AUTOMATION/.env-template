# System Under Test (SUT) SSH Configuration
SUT_SSH_USER=your_ssh_username
SUT_SSH_PASSWORD=your_ssh_password

# JMeter SSH Configuration
JMETER_SSH_USER=your_ssh_username
JMETER_SSH_PASSWORD=your_ssh_password

# VM Guest SSH Configuration (only needed for spring_vm_* experiment types)
VM_SSH_USER=your_vm_ssh_username
VM_SSH_PASSWORD=your_vm_ssh_password
