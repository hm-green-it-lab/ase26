SUT_HOST=127.0.0.1
SUT_BASE_DIR=/home/user/test
# {user}needs nopassword for the following processes
# sudo visudo
# {user} ALL=(ALL) NOPASSWD: /usr/bin/java, /bin/sh, /bin/kill, /usr/bin/chown

JMETER_HOST=jmeter.example.edu
JMETER_BASE_DIR=/home/jmeter/test

LOCAL_BASE_DIR=./tools
# Download URLs for local tool JARs.
# If a JAR is missing at the configured path it will be downloaded automatically.
# Leave empty to disable auto-download (a clear error is raised instead).
RITTAL_JAR_URL=https://github.com/hm-green-it-lab/rittal-reader/releases/download/v0.0.2/rittal-reader-1.0-runner.jar
HTTP_LOGGER_JAR_URL=https://github.com/hm-green-it-lab/http-logger/releases/download/v0.0.1/http-logger-1.0-runner.jar
# JARs that run remotely on the SUT – downloaded locally and then uploaded to remote_dir
PROCFS_JAR_URL=https://github.com/hm-green-it-lab/procfs-reader/releases/download/v0.0.1-beta/procfs-reader-1.0-runner.jar
POWERCAP_JAR_URL=https://github.com/hm-green-it-lab/powercap-reader/releases/download/v0.0.1-beta/powercap-reader-1.0-runner.jar

# Rittal PDU SNMP connection (used by the local rittal-reader JAR)
# Format: <ip>/<port>  e.g. 127.0.0.1/161
RITTAL_SNMP_ADDRESS=127.0.0.1/161
RITTAL_SNMP_COMMUNITY=public
# Comma-separated list of OIDs to read from the Rittal PDU
RITTAL_SNMP_OIDS=1.3.6.1.4.1.2606.7.4.2.2.1.11.2.373,1.3.6.1.4.1.2606.7.4.2.2.1.11.2.406

VM_BASE_DIR=/home/userv
VM_HOST=127.0.0.1
VM_PORT=2222